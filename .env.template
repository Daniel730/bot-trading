# Infrastructure
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
REDIS_APPENDONLY=yes

POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=bot_admin
# REQUIRED — choose a strong non-default value. If changing this for an
# existing Postgres volume, rotate the bot_admin database password too.
POSTGRES_PASSWORD=
POSTGRES_DB=trading_bot
DB_PATH=data/trading_bot.db

# AI & Voice (Intelligence Hub)
OPENAI_API_KEY=your_openai_key
GEMINI_API_KEY=your_gemini_key

# Alpaca API
# The default URL is Alpaca paper trading.
ALPACA_API_KEY=your_alpaca_key
ALPACA_API_SECRET=your_alpaca_secret
ALPACA_BASE_URL=https://paper-api.alpaca.markets
BROKERAGE_PROVIDER=ALPACA
# Optional hard budget cap for Alpaca execution (0 = use broker cash/buying power)
ALPACA_BUDGET_USD=0

# Market Data
POLYGON_API_KEY=your_polygon_key

# Telegram Notification (Human-in-the-Loop)
TELEGRAM_BOT_TOKEN=your_bot_token
TELEGRAM_CHAT_ID=your_chat_id

# Risk Management
MAX_ALLOCATION_PERCENTAGE=15.0
DEFAULT_WIN_PROBABILITY=0.55
DEFAULT_WIN_LOSS_RATIO=1.0
MAX_FRICTION_PCT=0.015
FLAT_ORDER_FRICTION_USD=0.5
MICRO_TRADE_THRESHOLD_USD=5.0
MIN_TRADE_VALUE=1.0
FINANCIAL_KILL_SWITCH_PCT=0.02
TARGET_CASH_PER_LEG=0
RISK_DRAWDOWN_ZERO_PCT=0.15
RISK_SHARPE_FLOOR=0.5
RISK_MULTIPLIER_CAP_LOW_SHARPE=0.1
RISK_SLIPPAGE_NORMAL=0.001
RISK_SLIPPAGE_HIGH_VOL=0.0005
VOLATILITY_ENTROPY_THRESHOLD=0.8
VOLATILITY_FALLBACK_ENTROPY=0.5
MARKET_REGIME_FALLBACK_CONFIDENCE=0.5
MARKET_REGIME_BASE_CONFIDENCE=0.7
MARKET_REGIME_EMA_BULL_FACTOR=1.01
MARKET_REGIME_EMA_BEAR_FACTOR=0.99
MARKET_REGIME_VOLATILITY_HIGH=0.30
MARKET_REGIME_VOLATILITY_LOW=0.10
MARKET_REGIME_ENTROPY_SPIKE=0.85
ORCH_AGENT_CONFIDENCE_THRESHOLD=0.5
ORCH_FUNDAMENTAL_DEFAULT_SCORE=50
ORCH_FUNDAMENTAL_VETO_SCORE=40
ORCH_ACCURACY_LOW_THRESHOLD=0.4
ORCH_ACCURACY_HIGH_THRESHOLD=0.7
ORCH_ACCURACY_LOW_MULTIPLIER=0.7
ORCH_ACCURACY_HIGH_MULTIPLIER=1.1
GLOBAL_STRATEGY_ACCURACY_DEFAULT=0.5

# Whale watcher is a crypto-only context/risk filter. Provider ingestion should
# refresh Redis summaries outside the orchestrator hot path.
WHALE_WATCHER_ENABLED=true
WHALE_WATCHER_ROLLING_WINDOW_SECONDS=1800
WHALE_WATCHER_CACHE_TTL_SECONDS=3600
WHALE_WATCHER_MAX_EVENTS_PER_SYMBOL=250
WHALE_WATCHER_MIN_VALUE_USD=5000000
WHALE_WATCHER_EXTREME_VALUE_USD=50000000
WHALE_WATCHER_VETO_SCORE=0.85
WHALE_WATCHER_VETO_MIN_EVENTS=2
WHALE_WATCHER_RISK_MULTIPLIER=0.85
WHALE_WATCHER_SUPPORT_MULTIPLIER=1.05

COINTEGRATION_MIN_OBSERVATIONS=20
COINTEGRATION_PVALUE_THRESHOLD=0.05
PORTFOLIO_RISK_FREE_RATE=0.02
SGOV_SWEEP_TICKER=SGOV
MIN_SWEEP_THRESHOLD=10.0

# Monitor / Signal thresholds
MONITOR_ENTRY_ZSCORE=2.0
MONITOR_MIN_AI_CONFIDENCE=0.5
ORCHESTRATOR_TIMEOUT_SECONDS=8.0
MARKET_DATA_TIMEOUT_SECONDS=8.0
MARKET_DATA_BATCH_SIZE=30
MARKET_DATA_BATCH_CONCURRENCY=3
SPREAD_GUARD_MAX_PCT=0.003
TAKE_PROFIT_ZSCORE=0.5
STOP_LOSS_ZSCORE=3.5
SCAN_INTERVAL_SECONDS=15

# LIVE_CAPITAL_DANGER: If true, bot refuses to boot if L2 entropy baselines are missing.
# Use with extreme caution.
LIVE_CAPITAL_DANGER=false

# Operational
PAPER_TRADING=true
PAPER_TRADING_STARTING_CASH=10000
VITE_API_TIMEOUT_MS=15000
ALLOW_LIVE_APPROVAL_WITHOUT_TELEGRAM=false
ACCOUNT_CURRENCY=EUR
REGION=US
MARKET_TIMEZONE=America/New_York
LOG_LEVEL=INFO

# DEV_MODE: Enables 24/7 testing via Crypto pairs (BTC-USD, SOL-USD) as proxies.
# Bypasses NYSE/NASDAQ market hours.
# WARNING: DEV_MODE=true randomizes prices in DataService and bypasses NYSE hour checks.
# NEVER set true in production — it generates false signals and skips real risk guards.
DEV_MODE=false

SEC_USER_AGENT="Project-Arbitrage-Elite admin@example.com"

# DASHBOARD_TOKEN: Secure token for the Adaptive Intelligence Web UI.
# REQUIRED — leave blank; operators must choose a strong value (e.g. `openssl rand -hex 32`).
# Never check the real value into source control.
DASHBOARD_TOKEN=
DASHBOARD_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:5173,http://127.0.0.1:5173,http://localhost:8080,http://127.0.0.1:8080
# Optional CORS regex. Leave blank to allow localhost, private LAN IPs, Tailscale IPs, and Raspberry Pi hostnames.
DASHBOARD_ALLOWED_ORIGIN_REGEX=

# Execution Engine (Feature 027 - gRPC)
EXECUTION_ENGINE_HOST=execution-engine
EXECUTION_ENGINE_PORT=50051
DRY_RUN=true
LATENCY_ALARM_THRESHOLD_MS=10.0

# Operation Hours (America/New_York default)
START_HOUR=9
START_MINUTE=30
END_HOUR=16
END_MINUTE=0

# Pair eligibility and cointegration gates
BLOCK_CROSS_CURRENCY_PAIRS=true
BLOCK_LSE_PAIRS_FOR_SHORT_HOLD=true
ALLOW_EU_CONTINENTAL_OVERLAP=false
PAIR_MAX_ROUND_TRIP_COST_PCT=0.0125
COINTEGRATION_ROLLING_ENABLED=true
COINTEGRATION_ROLLING_WINDOW=60
COINTEGRATION_ROLLING_STEP=5
COINTEGRATION_ROLLING_PASS_RATE=0.7
KALMAN_USE_Q_INFLATION=true
KALMAN_Q_SESSION_FACTOR=5.0
KALMAN_Q_SESSION_BARS=10
MONITOR_ENTRY_ZSCORE_COST_SCALING_ENABLED=false
MONITOR_ENTRY_ZSCORE_COST_BASELINE=0.0015
MONITOR_ENTRY_ZSCORE_COST_SCALING_CAP=3.0

# Legacy/Fallback
DATABASE_URL=

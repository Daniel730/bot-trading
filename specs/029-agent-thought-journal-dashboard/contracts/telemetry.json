{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "TelemetryUpdate",
  "type": "object",
  "required": ["type", "timestamp", "data"],
  "properties": {
    "type": {
      "type": "string",
      "enum": ["risk", "thought", "status"]
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "data": {
      "type": "object",
      "oneOf": [
        {
          "properties": {
            "risk_multiplier": { "type": "number" },
            "max_drawdown_pct": { "type": "number" },
            "volatility_status": { "type": "string" },
            "l2_entropy": { "type": "number" }
          }
        },
        {
          "properties": {
            "agent_name": { "type": "string" },
            "signal_id": { "type": "string" },
            "ticker_pair": { "type": "string" },
            "thought": { "type": "string" },
            "verdict": { "type": "string" }
          }
        },
        {
          "properties": {
            "stage": { "type": "string" },
            "details": { "type": "string" }
          }
        }
      ]
    }
  }
}

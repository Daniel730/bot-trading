{
  "name": "PortfolioManagerAgent",
  "interface": "orchestrate",
  "input": {
    "user_id": "TEXT",
    "signals": [
      {
        "ticker": "TEXT",
        "agent_name": "TEXT",
        "confidence": "DECIMAL (0-1)",
        "signal": "BUY|SELL|HOLD",
        "reasoning": "TEXT"
      }
    ],
    "macro_data": {
      "interest_rate": "DECIMAL",
      "inflation": "DECIMAL",
      "market_trend": "BULL|BEAR|NEUTRAL"
    }
  },
  "output": {
    "decision": "EXECUTE|REJECT|SCALE",
    "allocation": "DECIMAL (fiat amount)",
    "thesis_summary": "TEXT",
    "risk_veto": "BOOLEAN",
    "risk_reason": "TEXT (optional)"
  }
}
